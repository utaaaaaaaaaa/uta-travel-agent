# UTA Travel Agent - Docker 环境变量
# 复制此文件为 .env 并填写你的配置

# ===================
# LLM Provider 配置
# ===================
# 选择一个: mock, anthropic, openai, glm, deepseek
LLM_PROVIDER=glm

# ===================
# API Keys (根据上面选择的 provider 填写)
# ===================

# 智谱 GLM (推荐国内用户)
GLM_API_KEY=your-glm-api-key-here

# OpenAI
# OPENAI_API_KEY=your-openai-key

# DeepSeek
# DEEPSEEK_API_KEY=your-deepseek-key

# Anthropic Claude
# ANTHROPIC_API_KEY=your-anthropic-key
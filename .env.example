# UTA Travel Agent - Environment Variables

# ===================
# API Gateway (Go)
# ===================
HTTP_PORT=8080
LLM_PROVIDER=mock  # Options: mock, anthropic, openai, glm, deepseek
LLM_GRPC_ADDR=localhost:50051

# ===================
# LLM Provider Settings
# ===================

# Choose your LLM provider by setting LLM_PROVIDER above
# Then configure the corresponding API key below

# Anthropic Claude (LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# GLM 智谱 AI (LLM_PROVIDER=glm)
GLM_API_KEY=your-glm-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash

# DeepSeek (LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===================
# Python gRPC Services
# ===================
GRPC_PORT=50051

# ===================
# Storage
# ===================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=uta
POSTGRES_PASSWORD=uta_dev_password
POSTGRES_DB=uta_travel

REDIS_HOST=localhost
REDIS_PORT=6379

QDRANT_HOST=localhost
QDRANT_PORT=6333

# ===================
# Frontend
# ===================
NEXT_PUBLIC_API_URL=http://localhost:8080
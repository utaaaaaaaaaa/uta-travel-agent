# UTA Travel Agent - Environment Variables

# ===================
# API Gateway (Go)
# ===================
HTTP_PORT=8080
LLM_PROVIDER=mock  # Options: mock, anthropic, openai, glm, deepseek

# ===================
# LLM Provider Settings
# ===================

# Choose your LLM provider by setting LLM_PROVIDER above
# Then configure the corresponding API key below

# Anthropic Claude (LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# GLM 智谱 AI (LLM_PROVIDER=glm or default)
LLM_API_KEY=your-glm-key
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-4-flash

# DeepSeek (LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===================
# gRPC Services
# ===================
# Embedding Service (Python)
EMBEDDING_ADDR=localhost:50052
GRPC_PORT=50052

# ===================
# Storage - PostgreSQL
# ===================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=uta_travel
DATABASE_SSLMODE=disable
# Or use connection string
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/uta_travel?sslmode=disable

# Legacy postgres config (for compatibility)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=uta_travel

# ===================
# Storage - Redis
# ===================
REDIS_HOST=localhost
REDIS_PORT=6379

# ===================
# Storage - Qdrant Vector DB
# ===================
QDRANT_HOST=localhost
QDRANT_PORT=6334

# ===================
# Frontend (Next.js)
# ===================
NEXT_PUBLIC_API_URL=http://localhost:8080